/* pages/index/index.wxss */
/* 1. 全局重置 */
view, text, navigator, input { box-sizing: border-box; }
page { background-color: #fff; padding-bottom: 80rpx; }
.container { padding: 0 40rpx; width: 100%; }

/* ================== Header ================== */
.header-section { padding: 20rpx 0 10rpx; text-align: center; } /* 稍微改小一点padding */
.brand-title { font-size: 40rpx; font-weight: 800; color: #000; letter-spacing: 2rpx; } 
.brand-subtitle { font-size: 14rpx; color: #999; letter-spacing: 4rpx; margin-top: 6rpx; text-transform: uppercase; font-weight: bold; }

/* ================== 蓝色数据板 (修正：更窄、更高) ================== */
.stats-board {
  background: #00539C;
  border-radius: 20rpx;
  padding: 60rpx 0 40rpx; 
  color: white;
  box-shadow: 0 10rpx 30rpx rgba(0, 83, 156, 0.25);
  
  /* 关键修改：宽度缩到 290rpx，绝对够窄了 */
  width: 290rpx; 
  margin: 10rpx auto 50rpx; 
  
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-row { 
  display: flex; 
  justify-content: center; 
  align-items: flex-start;
  width: 100%;
  gap: 16rpx; /* 间距稍微收一点 */
}

.stat-item { 
  display: flex; 
  flex-direction: column; 
  align-items: center; 
}

.stat-label-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 4rpx;
}

.stat-zh { font-size: 20rpx; font-weight: bold; white-space: nowrap; opacity: 0.95; }
.stat-en { font-size: 12rpx; opacity: 0.6; text-transform: uppercase; margin-top: 2rpx; font-weight: 500;}

.stat-value { font-size: 64rpx; font-weight: bold; line-height: 1; margin-top: 6rpx; letter-spacing: -2rpx; }

.divider-line {
  width: 1px;
  height: 60rpx;
  background: rgba(255,255,255,0.3);
  margin-top: 10rpx;
}

.finance-link-container { text-align: center; margin-top: 24rpx; }
.finance-link { font-size: 14rpx; opacity: 0.5; letter-spacing: 2rpx; font-weight: bold; }

/* ================== 核心按钮区 ================== */
.action-grid { 
  display: flex; 
  justify-content: center; 
  gap: 40rpx; 
  margin-bottom: 20rpx; 
  width: 100%; 
}

.action-btn {
  width: 200rpx;
  height: 200rpx;
  border: 1px solid #8ab4d7; 
  border-radius: 20rpx;
  display: flex; 
  flex-direction: column; 
  align-items: center; 
  justify-content: center;
  background: #fff;
  box-shadow: none; 
}

.plus { font-size: 40rpx; color: #00539C; margin-bottom: 12rpx; line-height: 1; font-weight: 400; }
.btn-zh { font-size: 28rpx; font-weight: bold; color: #00539C; white-space: nowrap; }
.btn-en { font-size: 16rpx; color: #b0c4de; margin-top: 6rpx; font-weight: 500; }

.text-link-row { text-align: center; margin-bottom: 0; margin-top: 10rpx;}
.text-link-row text { font-size: 20rpx; color: #BBB; letter-spacing: 2rpx; font-weight: bold; }

/* ================== 目录区 (修正：大幅下移) ================== */
.directory-section { 
  /* 关键修改：从 60 改为 100，往下狠狠推 */
  margin-top: 130rpx; 
  margin-bottom: 20rpx; 
  width: 100%; 
  padding: 0 10rpx; 
}

.section-title-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 24rpx; /* 标题和搜索框的距离也拉大一点点 */
}

.title-group { display: flex; align-items: baseline; }
.main-title { font-size: 32rpx; font-weight: 800; color: #333; margin-right: 12rpx; }
.tag-blue { font-size: 20rpx; color: #00539C; font-weight: bold; margin-right: 10rpx; }
.tag-gray { font-size: 20rpx; color: #DDD; }

.search-pill-centered {
  background: #f9f9f9; 
  height: 70rpx; 
  border-radius: 35rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 420rpx; 
  margin: 0 auto;
}

.search-icon { font-size: 24rpx; margin-right: 10rpx; opacity: 0.5; color: #333; } /* 图标加深 */
.search-pill-centered input { 
  font-size: 24rpx; 
  width: 220rpx; 
  text-align: center; 
  height: 100%; 
  color: #333; /* 输入文字颜色加深 */
  font-weight: 500; /* 字体加粗 */
}

/* ================== 家长入口（仅 from=parent 时整页） ================== */
.parent-gateway {
  padding: 80rpx 40rpx 60rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.parent-gateway-title { font-size: 52rpx; font-weight: 800; color: #00539C; letter-spacing: 4rpx; }
.parent-gateway-sub { font-size: 24rpx; color: #999; margin-top: 16rpx; margin-bottom: 80rpx; }
.parent-gateway .parent-entry-row { width: 100%; margin: 20rpx 0; }
.parent-gateway-tip { font-size: 24rpx; color: #999; margin-top: 60rpx; text-align: center; line-height: 1.6; padding: 0 20rpx; }

.parent-entry-row {
  margin: 24rpx 0;
  padding: 28rpx;
  background: #EFF6FF;
  border-radius: 16rpx;
  border: 1rpx solid #8ab4d7;
  text-align: center;
}
.parent-entry-text { font-size: 30rpx; color: #00539C; font-weight: 600; }

/* ================== 列表项 ================== */
.student-list { width: 100%; padding: 0 10rpx; }

.student-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 0;
  border-bottom: 1px solid #f9f9f9;
}

.avatar {
  width: 90rpx; height: 90rpx;
  background: #EFF6FF; color: #00539C;
  border-radius: 50%;
  font-size: 36rpx; font-weight: 800;
  display: flex; align-items: center; justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.student-info { flex: 1; overflow: hidden; margin-right: 10rpx; }

.name-line { display: flex; align-items: baseline; margin-bottom: 8rpx; white-space: nowrap; }
.student-name { font-size: 32rpx; font-weight: bold; color: #333; margin-right: 12rpx; }
.link-blue { font-size: 20rpx; color: #00539C; font-weight: bold; margin-right: 10rpx; }
.link-gray { font-size: 20rpx; color: #aaa; }

.status-line { font-size: 24rpx; color: #999; }

.checkin-btn {
  font-size: 22rpx;
  color: #00539C;
  border: 1px solid #00539C;
  padding: 10rpx 24rpx; 
  border-radius: 10rpx; 
  background: #fff;
  white-space: nowrap;
  flex-shrink: 0;
}
                                                                                                                                                         /* Lessons color rules (teacher mode) */
.lessons-low {      /* 1 节：橙色预警 */
  color: #ff9800;
  font-weight: 700;
}
.lessons-zero {     /* 0 节：红色耗尽 */
  color: #e53935;
  font-weight: 800;
}

/* 审核员页底部：家长入口小字链接（仅 from=parent 时显示） */
.parent-entry-footer {
  margin-top: 40rpx; padding: 24rpx 0 60rpx; text-align: center;
  font-size: 24rpx; color: #999;
}
.parent-entry-footer-label { margin-right: 8rpx; }
.parent-entry-footer-link { color: #00539C; text-decoration: underline; }
.parent-entry-footer-sep { color: #ccc; margin: 0 4rpx; }


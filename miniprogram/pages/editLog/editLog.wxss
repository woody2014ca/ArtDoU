.container { padding: 40rpx; min-height: 100vh; background: #fff; }
.header-section { margin-bottom: 40rpx; padding-bottom: 24rpx; border-bottom: 1rpx solid #eee; }
.header-section .title { font-size: 36rpx; font-weight: bold; color: #333; display: block; }
.header-section .sub { font-size: 24rpx; color: #999; margin-top: 12rpx; display: block; }

.form-group { margin-bottom: 36rpx; }
.form-group .label { font-size: 28rpx; font-weight: bold; color: #333; margin-bottom: 16rpx; display: block; }
.textarea { width: 100%; min-height: 120rpx; background: #f5f5f5; border-radius: 12rpx; padding: 20rpx; font-size: 28rpx; box-sizing: border-box; }
.textarea.memo { min-height: 180rpx; }
.count { font-size: 22rpx; color: #999; margin-top: 8rpx; display: block; }

.image-box { width: 200rpx; height: 200rpx; background: #f5f5f5; border-radius: 12rpx; position: relative; overflow: hidden; }
.preview-img { width: 100%; height: 100%; }
.plus-overlay { position: absolute; left: 0; top: 0; right: 0; bottom: 0; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,0.1); }
.plus { font-size: 48rpx; color: #00539C; }
.thumbs-wrap { margin-top: 20rpx; }
.thumbs-count { font-size: 24rpx; color: #666; }
.thumbs-row { white-space: nowrap; margin-top: 12rpx; }
.thumb { width: 120rpx; height: 120rpx; border-radius: 8rpx; margin-right: 16rpx; display: inline-block; vertical-align: middle; }

.submit-btn { width: 100%; height: 88rpx; margin-top: 60rpx; background: #00539C; color: #fff; font-size: 32rpx; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; }
button.submit-btn::after { border: none; }

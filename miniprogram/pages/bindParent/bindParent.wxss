/* pages/bindParent/bindParent.wxss */
.container { padding: 60rpx 50rpx 80rpx; background: #fff; min-height: 100vh; }

.header-section { padding-bottom: 50rpx; margin-bottom: 40rpx; border-bottom: 1rpx solid #f0f0f0; }
.brand-small { color: #005387; font-size: 32rpx; font-weight: bold; display: block; margin-bottom: 12rpx; }
.main-title { font-size: 52rpx; font-weight: 800; color: #1a1a1a; display: block; }
.sub-title-en { font-size: 26rpx; color: #999; margin-top: 12rpx; display: block; }

.input-group { margin-bottom: 36rpx; }
.label { font-size: 32rpx; font-weight: bold; color: #444; margin-bottom: 20rpx; display: block; }
.input-phone {
  width: 100%; height: 96rpx; background: #f4f7f9; border-radius: 16rpx;
  padding: 0 32rpx; font-size: 34rpx; color: #333; border: 2rpx solid #e1e8ed; box-sizing: border-box;
}
.placeholder { color: #bbb; }

.tip { font-size: 26rpx; color: #888; margin-bottom: 30rpx; line-height: 1.5; }

.openid-section {
  margin-bottom: 40rpx; padding: 24rpx; background: #f8f8f8; border-radius: 12rpx; border: 1rpx solid #eee;
}
.openid-label { font-size: 26rpx; color: #666; display: block; margin-bottom: 12rpx; }
.openid-value-row { display: flex; align-items: center; justify-content: space-between; }
.openid-value { font-size: 22rpx; color: #333; word-break: break-all; flex: 1; margin-right: 16rpx; }
.openid-copy { font-size: 28rpx; color: #005387; font-weight: 600; }
.openid-tip { font-size: 22rpx; color: #999; margin-top: 12rpx; display: block; line-height: 1.5; }

.brand-submit-btn {
  width: 100%; height: 96rpx; line-height: 96rpx; background: #005387;
  color: #fff; font-size: 34rpx; font-weight: 600; border-radius: 16rpx; border: none;
}
.brand-submit-btn[disabled] { opacity: 0.7; }

.back-row { margin-top: 40rpx; text-align: center; font-size: 28rpx; color: #005387; }

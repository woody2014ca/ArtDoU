<view style="height: 120rpx;"></view> <!-- 占位防止挡住下面 -->
<view wx:if="{{loading}}" class="loading-view" style="height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; background: #fff;">
  <view style="color: #005387; font-size: 58rpx; font-family: 'Serif', serif; font-weight: bold; letter-spacing: 6rpx;">ArtDoU</view>
  <view style="color: #999; font-size: 26rpx; margin-top: 30rpx;">
    {{ isAudit ? '正在同步资产数据...' : '正在进入艺术展厅...' }}
  </view>
</view>

<block wx:elif="{{isAuthorized}}">
  <view class="container">
    <view class="brand-title">ArtDoU</view>

    <view class="parent-header">
      <view class="student-info">
        <text class="student-name">{{student.name || ''}}</text>
        <text class="artist-tag">{{ isAudit ? '专业版账户 / Premium Member' : '小小艺术家 / The Little Artist' }}</text>
      </view>
      
      <view class="lessons-stat" wx:if="{{!isGuest && !isViewingSharedLink}}">
  <text class="lessons-label">{{ isAudit ? '资产存量 / Units left' : '剩余课时 / Lessons left' }}</text>
  <text class="lessons-num">: {{student.left_classes || 0}}</text>
</view>
    </view>

    <view wx:if="{{recentLeave}}" class="leave-status-bar">
      <view class="status-indicator {{recentLeave.status === 'pending' ? 'is-waiting' : 'is-approved'}}"></view>
      <view class="status-content">
        <text class="status-label">{{ isAudit ? '排期调整反馈：' : '最近请假反馈：' }}</text>
        <text class="status-value">
          {{recentLeave.date}} {{recentLeave.status === 'pending' ? (isAudit ? '校对中' : '审核中') : (isAudit ? '已确认' : '已批准')}}
        </text>
      </view>
    </view>

    <view wx:if="{{!isGuest && !isViewingSharedLink && student.left_classes <= 1}}" class="renew-alert" bindtap="goToPayment">
      <view class="renew-content">
        <text class="renew-title">{{ isAudit ? '资产存量预警 / Low Balance' : '余课不足，请及时续费 / Renewal' }}</text>
        <text class="renew-detail">
          {{ isAudit ? '当前存量仅剩 ' : '当前仅剩 ' }}
<text class="lessons {{student.left_classes === 0 ? 'lessons-zero' : (student.left_classes === 1 ? 'lessons-low' : '')}}">
  {{student.left_classes}}
</text>
{{ isAudit ? ' 单位' : ' 节课' }}

        </text>
      </view>
    </view>

    <view class="achievement-card">
  <view class="ach-item">
    <text class="ach-num">{{works.length || 0}}</text>
    <view class="ach-label-group">
      <text class="ach-zh" >{{ isAudit ? '资产存证' : '创作作品' }}</text>
      <text class="ach-en">{{ isAudit ? 'LOGGED ASSETS' : 'WORKS' }}</text>
    </view>
  </view>
  
  <view class="ach-line" style="height: 100rpx !important; background: rgba(255,255,255,0.6) !important; width: 2rpx !important;"></view>
  
  <view class="ach-item">
    <text class="ach-num">{{totalRewards || 0}}</text>
    <view class="ach-label-group">
      <text class="ach-zh" >{{ isAudit ? '激励分值' : '获得奖励' }}</text>
      <text class="ach-en">{{ isAudit ? 'INCENTIVE POINTS' : 'REWARDS' }}</text>
    </view>
  </view>
</view>

    <!-- 我也要报名：放在蓝色大方框下面，与 ART GALLERY 隔开 -->
    <view wx:if="{{isGuest}}" class="enroll-row">
      <button class="submit-btn" bindtap="goToEnroll">🎁 我也要报名 (首次课优享价)</button>
    </view>

    <view class="action-grid" wx:if="{{!isGuest}}">
      <view class="action-item" bindtap="goToLeave" wx:if="{{!isAdmin}}">
        <view class="action-icon">🗓</view>
        <text class="action-text">{{ isAudit ? '排期变更' : '请假条' }}</text>
      </view>

      <view class="action-item" bindtap="generatePoster">
        <view class="action-icon">📜</view>
        <text class="action-text">{{ isAudit ? '导出档案' : '生成海报' }}</text>
      </view>

      <button class="action-item share {{highlightShare ? 'pulse-anim' : ''}}" open-type="share">
        <view class="action-icon">🎁</view>
        <text class="action-text">{{ isAdmin ? '通知家长' : (isAudit ? '推荐激励' : '分享有奖') }}</text>
      </button>
    </view>

    <!-- 艺术成长展厅：标题正下方为图片，整体居中 -->
    <view class="gallery-section">
      <view class="gallery-header">
        <text class="en">{{ isAudit ? 'ASSET LOG' : 'ART GALLERY' }}</text>
        <text class="zh">{{ isAudit ? '资产流转明细' : '艺术成长展厅' }}</text>
      </view>

      <view class="works-grid">
        <block wx:for="{{works}}" wx:key="_id">
          
          <!-- A面：审核模式 (列表样式) -->
          <view wx:if="{{isAudit}}" class="audit-log-item" style="display:flex; justify-content:space-between; padding:30rpx 0; border-bottom:1px solid #f6f6f6;">
             <view>
               <text style="font-size:28rpx; color:#333; font-weight:bold;">{{item.note || '资产变动记录'}}</text>
               <view style="font-size:22rpx; color:#999; margin-top:8rpx;">{{item.date}}</view>
             </view>
             <view style="color:#005387; font-weight:bold; font-size:24rpx;">查看凭证 ></view>
          </view>

          <!-- B面：正常模式 (图片卡片，支持多图：封面为第一张，点击预览全部) -->
          <view wx:else class="work-card" bindtap="previewImage" data-index="{{index}}" data-src="{{item.work_imgs && item.work_imgs[0] ? item.work_imgs[0] : (item.work_img || item.work_photo)}}">
            <image src="{{item.work_imgs && item.work_imgs[0] ? item.work_imgs[0] : (item.work_img || item.work_photo)}}" mode="aspectFill" class="work-cover"></image>
            <view class="work-info">
              <text class="work-date">日期: {{item.date}}</text>
              <text wx:if="{{item.work_imgs && item.work_imgs.length > 1}}" class="work-multi">共{{item.work_imgs.length}}张</text>
            </view>
          </view>

        </block>
        
        <!-- 3. 暂无作品 -->
        <view wx:if="{{works.length === 0}}" class="empty-holder">
          {{ isAudit ? '暂无存证记录' : '暂无作品展示，期待下一次创作' }}
        </view>
      </view>
    </view>

    <canvas 
  type="2d" 
  id="posterCanvas" 
  style="width: 750rpx; height: {{canvasHeight}}rpx; position: fixed; left: 200%; top: 0;"
></canvas>

  </view>
</block>

<view wx:else class="restricted-view" style="padding: 100rpx 40rpx; text-align: center; background: #fff; height: 100vh;">
  <view style="margin-top: 100rpx;">
    <view style="font-size: 80rpx;">{{ isAudit ? '📊' : '🎨' }}</view>
    <view style="color: #333; font-weight: bold; margin-top: 40rpx; font-size: 32rpx;">
      {{ isAudit ? '个人资产明细存证空间' : 'ArtDoU 艺术展厅私密空间' }}
    </view>
    <view style="color: #999; font-size: 26rpx; margin-top: 30rpx; line-height: 1.8; text-align: justify;">
      {{ isAudit ? '本模块用于关联成员查看其名下的视觉资产存档、存量消耗明细及结余统计报表。' : '本模块用于家长查看孩子在艺术课上的创作存档、消课记录及精美的成长报告。' }}
      \n为了保护隐私与数据安全，此空间仅对已绑定的受邀账户开放。
    </view>
  </view>
  
  <view style="margin-top: 100rpx; border-top: 1rpx solid #eee; padding-top: 60rpx;">
    <text style="color: #ccc; font-size: 22rpx;">未关联账户？请咨询管理人员进行核身开通</text>
    <button open-type="contact" style="margin-top: 30rpx; background: #005387; color: #fff; border-radius: 10rpx; font-size: 28rpx; width: 360rpx;">
      {{ isAudit ? '咨询管理人员 / Consult' : '联系艺术老师 / Contact' }}
    </button>
  </view>
</view>
.container {
  padding: 40rpx;
  padding-bottom: 260rpx;  /* 为底部按钮预留足够可滚空间，避免只露半截 */
  background: #f8f8f8;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

.header-section { width: 100%; margin-bottom: 40rpx; }
.title { font-size: 40rpx; font-weight: 900; color: #1a1a1a; display: block; }
.subtitle { font-size: 16rpx; color: #00539C; letter-spacing: 6rpx; font-weight: bold; }

/* 海报预览尺寸 (按照 3:4 比例) */
.poster-canvas {
  background: #fff;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.1);
  border-radius: 8rpx;
  display: block;
}

.btn-group {
  width: 100%;
  margin-top: 6rpx;   /* 红条下面间距再压小一点 */
  /* ✅ 底部安全区留白放在整个按钮组上，避免两个蓝色按钮被吃掉 */
  padding-bottom: 16px;
  padding-bottom: calc(16px + constant(safe-area-inset-bottom));
  padding-bottom: calc(16px + env(safe-area-inset-bottom));
}
.save-btn {
  background: #00539C;
  color: #fff;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: bold;
  display: block;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  margin-bottom: 12rpx;  /* 两个蓝按钮之间竖向间距再压一点 */
}
.back-btn {
  background: none;
  color: #999;
  font-size: 24rpx;
  text-align: center;
  line-height: 40rpx;
  padding-bottom: 0;  /* ✅ 不再用返回自己撑安全区，防止只剩半截 */
}
/* 新增样式 */
.final-image {
  width: 100%;
  border-radius: 12rpx;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.1);
  display: block; /* 消除图片底部空隙 */
}

.loading-placeholder {
  width: 100%;
  height: 600rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f8f8f8;
  border-radius: 12rpx;
}

/* 覆盖原来的 .poster-canvas 样式，因为我们已经把它移出屏幕了 */
.poster-preview {
  width: 690rpx;
  margin: 20rpx auto;
  /* 不再强制最小高度，让按钮紧跟在海报图片后面 */
  min-height: 0;
  padding-bottom: 0; /* 去掉海报与按钮之间额外留白 */
  box-sizing: border-box;
}
/* ===== 作品选择面板 ===== */
.picker-panel {
  width: 690rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.06);
}

.picker-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #1a1a1a;
}

.picker-subtitle {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  margin-bottom: 18rpx;
}

/* 缩略图网格 */
.thumb-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.thumb-item {
  width: 210rpx;     /* 3列 */
  height: 210rpx;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
  background: #f2f2f2;
}

.thumb-img {
  width: 100%;
  height: 100%;
  display: block;
}

.thumb-selected {
  outline: 4rpx solid #00539C;
  outline-offset: -4rpx;
}

.thumb-mask {
  position: absolute;
  left: 0; top: 0; right: 0; bottom: 0;
  background: rgba(0, 83, 156, 0.28);
  display: flex;
  align-items: flex-start;
  justify-content: flex-end;
  padding: 12rpx;
}

.thumb-check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  background: #00539C;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
}

/* 按钮区 */
.picker-actions {
  margin-top: 24rpx;
}

/* 生成中遮罩 */
.loading-overlay {
  position: fixed;
  left: 0; top: 0; right: 0; bottom: 0;
  background: rgba(255,255,255,0.85);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}
.loading-box {
  background: #fff;
  padding: 28rpx 30rpx;
  border-radius: 14rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.12);
}
.loading-text {
  font-size: 26rpx;
  color: #333;
  font-weight: 700;
}

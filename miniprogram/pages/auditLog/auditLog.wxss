.container { padding: 48rpx 40rpx; background: #fff; min-height: 100vh; }
.header-section { margin-bottom: 48rpx; padding-bottom: 32rpx; border-bottom: 1rpx solid #eee; }
.header-section .label { font-size: 24rpx; color: #999; display: block; margin-bottom: 8rpx; }
.header-section .name { font-size: 40rpx; font-weight: bold; color: #333; display: block; }
.header-section .current { font-size: 28rpx; color: #00539C; margin-top: 16rpx; display: block; }

.form-group { margin-bottom: 36rpx; }
.form-group .label { font-size: 28rpx; font-weight: bold; color: #333; margin-bottom: 16rpx; display: block; }
.input {
  width: 100%; height: 88rpx; background: #f5f5f5; border-radius: 12rpx;
  padding: 0 28rpx; font-size: 30rpx; color: #333; box-sizing: border-box;
}

.op-row { display: flex; gap: 24rpx; }
.op-btn {
  flex: 1; min-width: 280rpx; height: 80rpx; display: flex; align-items: center; justify-content: center;
  font-size: 30rpx; font-weight: 600; border-radius: 12rpx;
  background: #f0f0f0; color: #666;
}
.op-btn.active { background: #00539C; color: #fff; }

.submit-btn {
  width: 100%; height: 96rpx; margin-top: 60rpx;
  background: #00539C; color: #fff; font-size: 32rpx; font-weight: 600;
  border-radius: 16rpx; border: none;
  display: flex !important; align-items: center !important; justify-content: center !important;
  padding: 0; line-height: 1;
}
button.submit-btn::after { border: none; }

/* pages/leaveRequest/leaveRequest.wxss */

/* 1. 页面容器 - 核心修复 */
.container {
  display: block !important;      /* 【核心】覆盖全局的 flex，改回默认块级布局 */
  padding: 60rpx 40rpx;
  background: #fff;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 2. 头部：ArtDoU + 标题 */
.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.brand-title {
  color: #005387;
  font-size: 58rpx;
  font-family: "Times New Roman", serif;
  font-weight: bold;
  letter-spacing: 4rpx;
  display: block;
  margin-bottom: 10rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 900;
  color: #333;
  display: block;
}

.subtitle {
  font-size: 20rpx;
  color: #00539C;
  letter-spacing: 6rpx;
  margin-top: 10rpx;
  display: block;
  text-transform: uppercase;
}

/* 3. 表单区域 */
.form-card {
  width: 100%; /* 确保表单区域占满 */
}

.input-item {
  margin-bottom: 50rpx;
  width: 100%; 
}

/* 标签文字 */
.label {
  font-size: 26rpx;
  color: #666;
  font-weight: bold;
  text-align: center;
  display: block;
  margin-bottom: 20rpx;
}

/* 4. 两个灰色输入框：宽 75% */
/* 日期选择器 */
.picker-box {
  width: 75%;            /* 75% 宽度 */
  height: 80rpx;
  margin: 0 auto;        /* 居中 */
  background: #f8f8f8;
  border-radius: 12rpx;
  display: flex;       
  align-items: center;
  justify-content: center;
}

.picker-inner {
  width: 100%;
  text-align: center;
}

/* 原因输入框 */
.reason-text {
  width: 75%;            /* 75% 宽度 */
  height: 200rpx;
  margin: 0 auto;        /* 居中 */
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
  box-sizing: border-box;
  display: block;
  font-size: 28rpx;
}

.placeholder { color: #ccc; }
.val { color: #333; font-weight: bold; }

/* 5. 提交按钮 */
.submit-btn {
  width: 75% !important;
  height: 100rpx;
  margin-top: 80rpx;
  background: #00539C;
  color: #fff;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
  
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
}
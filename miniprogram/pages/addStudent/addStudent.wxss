/* 1. 页面容器 */
.container {
  display: block !important;      /* 覆盖全局flex */
  padding: 60rpx 40rpx;
  background: #fff;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 2. 头部美化 */
.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.brand-title {
  color: #005387;
  font-size: 58rpx;
  font-family: "Times New Roman", serif;
  font-weight: bold;
  letter-spacing: 4rpx;
  margin-bottom: 10rpx;
  display: block;
}

.title {
  font-size: 40rpx;
  font-weight: 900;
  color: #333;
  display: block;
  margin-bottom: 5rpx;
}

.subtitle {
  font-size: 20rpx;
  color: #00539C;
  letter-spacing: 6rpx;
  text-transform: uppercase;
  opacity: 0.8;
  display: block;
}

/* 3. 表单样式 */
.input-item {
  margin-bottom: 40rpx;
  width: 100%;
}

.label {
  font-size: 26rpx;
  color: #666;
  font-weight: bold;
  text-align: center;
  display: block;
  margin-bottom: 15rpx;
}

/* 核心：输入框美化 */
.input-box {
  width: 75% !important;          /* 75% 宽度 */
  height: 90rpx !important;       /* 高度适中 */
  margin: 0 auto !important;      /* 居中 */
  background: #f8f8f8 !important; /* 浅灰底色 */
  border-radius: 12rpx;
  text-align: center;
  font-size: 30rpx;
  color: #333;
  display: block;
}

/* 4. 按钮美化 */
.submit-btn {
  width: 75% !important;
  height: 100rpx;
  margin-top: 80rpx;
  background: #00539C;
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
  
  /* 按钮居中 */
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  margin-left: auto !important;
  margin-right: auto !important;
}
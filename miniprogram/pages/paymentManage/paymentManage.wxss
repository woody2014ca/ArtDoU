/** pages/paymentManage/paymentManage.wxss **/
.container { 
  padding: 60rpx 40rpx; 
  background: #fff; 
  min-height: 100vh; 
  box-sizing: border-box; 
}

/* 艺术标题排版 */
.header-box {
  margin-bottom: 60rpx;
  display: flex;
  flex-direction: column;
}
.title { font-size: 52rpx; font-weight: 900; color: #1a1a1a; }
.subtitle { font-size: 18rpx; color: #FAAD14; letter-spacing: 8rpx; font-weight: bold; margin-top: 15rpx; }

/* 缴费卡片列表 */
.payment-card {
  background: #fff; 
  border: 1.5rpx solid #f2f2f2; 
  border-radius: 24rpx;
  padding: 40rpx; 
  margin-bottom: 40rpx; 
  box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.03);
}

.main-row { 
  display: flex; 
  justify-content: space-between; 
  align-items: flex-start; 
}

.student-name { 
  font-size: 38rpx; 
  font-weight: bold; 
  color: #333;
  text-transform: capitalize; 
}
.tag-prospective { font-size: 22rpx; color: #00539C; margin-left: 12rpx; padding: 4rpx 12rpx; background: #EFF6FF; border-radius: 8rpx; }
.prospective-btn { background: #FAAD14 !important; }

.amount-group { text-align: right; }
.lesson-count { font-size: 32rpx; font-weight: 800; color: #00539C; display: block; }

/* 金额强调样式 */
.price-val { 
  font-size: 24rpx; 
  color: #FF4D4F; 
  font-weight: bold; 
  margin-top: 5rpx; 
  display: block;
}

.time-tip { font-size: 22rpx; color: #999; margin-top: 15rpx; display: block; }

/* 凭证图区域 */
.proof-section { margin: 30rpx 0; position: relative; }
.proof-img { width: 100%; height: 350rpx; border-radius: 12rpx; background: #f8f8f8; }
.zoom-tip { 
  font-size: 20rpx; color: #ccc; text-align: center; 
  margin-top: -10rpx; margin-bottom: 20rpx; 
}

/* 确认按钮：确保文字完美居中且不截断 */
.approve-btn {
  background: #00539C !important;
  color: #fff !important;
  font-size: 24rpx !important;
  font-weight: bold !important;
  border-radius: 50rpx !important;
  height: 90rpx !important;
  line-height: 90rpx !important;
  width: 100% !important;
  margin: 0 !important;
  padding: 0 !important;
  letter-spacing: 2rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.empty-state { text-align: center; padding-top: 200rpx; color: #ccc; font-size: 28rpx; }